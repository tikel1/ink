# ---------------------------------------------------------------------------
# Ink — backend configuration. Copy to .env; never commit it.
# ---------------------------------------------------------------------------

# Public HTTPS URL the device + phone reach this backend at.
PUBLIC_BASE_URL=http://localhost:8000

# --- Platform generation key (yours — the default payer) ---
IMAGE_PROVIDER=openai
PLATFORM_OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TEXT_MODEL=gpt-4o-mini

# --- Encryption for per-account keys at rest ---
# Generate with:  python -m backend.crypto
MASTER_ENCRYPTION_KEY=

# --- Admin token (guards the "require own key" endpoint) ---
ADMIN_TOKEN=

# --- Storage / scheduler ---
DATA_DIR=./data
GENERATION_LEAD_MINUTES=45
ENABLE_SCHEDULER=true

# --- New-device defaults ---
DEFAULT_TZ=Asia/Jerusalem
DEFAULT_LAT=32.0853
DEFAULT_LON=34.7818
DEFAULT_WAKE_HOUR=6
